{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>lab/renovate-config"
  ],
  "baseBranchPatterns": ["main"],
  "assignAutomerge": true,
  "assignees": ["@albdev-bot"],
  "reviewers": ["@naoalb"],
  "flux": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["kubernetes/hcloud/**"],
      "addLabels": ["kubernetes/hcloud"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["talos/hcloud/**"],
      "addLabels": ["talos/hcloud"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["bootstrap/hcloud/**"],
      "addLabels": ["bootstrap/hcloud"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["bootstrap/home/**"],
      "addLabels": ["bootstrap/home"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["talos/home/**"],
      "addLabels": ["talos/home"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["kubernetes/home/**"],
      "addLabels": ["kubernetes/home"]
    }
  ]
}
