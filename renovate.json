{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>lab/renovate-config"
  ],
  "baseBranchPatterns": ["main"],
  "assignAutomerge": true,
  "assignees": ["@onji-bot"],
  "reviewers": ["@naoalb"],
  "flux": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ],
    "pinDigests": false
  },
  "helm-values": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ],
    "pinDigests": false
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ],
    "pinDigests": false
  },
  "kustomize": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/",
      "/bootstrap/.+\\.ya?ml$/",
      "/talos/.+\\.ya?ml$/"
    ],
    "pinDigests": true
  },
  "packageRules": [
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["clusters/hcloud/**"],
      "addLabels": ["cluster/hcloud"]
    },
    {
      "description": "add cluster name to commit message",
      "matchFileNames": ["clusters/home/**"],
      "addLabels": ["cluster/home"]
    }
  ]
}
